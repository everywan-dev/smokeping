# ============================================
# SmokePing Docker - Variables de Entorno
# ============================================
# Copia este archivo a .env y personaliza los valores:
#   cp .env.example .env

# ============================================
# PUERTO DE ACCESO
# ============================================
# Puerto público donde estará disponible SmokePing
PORT=8080

# ============================================
# USUARIO Y GRUPO
# ============================================
# ID del usuario y grupo para permisos de archivos
# Ejecuta 'id' en tu terminal para ver tus valores
PUID=1000
PGID=1000

# ============================================
# ZONA HORARIA
# ============================================
# Lista: https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
TZ=Europe/Madrid

# ============================================
# INFORMACIÓN DE SMOKEPING
# ============================================
# Nombre del propietario (aparece en el footer)
SMOKEPING_OWNER=Mi Empresa

# Email de contacto
SMOKEPING_CONTACT=noc@miempresa.com

# Título de la aplicación
SMOKEPING_TITLE=Network Monitoring

# Hostname que aparece en los gráficos
# Este nombre aparece como "Last 3 Hours from [HOSTNAME]"
SMOKEPING_HOSTNAME=monitor-principal

# ============================================
# BRANDING (Opcional)
# ============================================
# Logo personalizado (ruta relativa a /usr/share/webapps/smokeping/)
# Por defecto: images/logo.svg
# Para usar tu logo: colócalo en frontend/images/
SMOKEPING_LOGO_URL=images/logo.svg

# Enlace de marca en el footer (dejar vacío para ocultar)
SMOKEPING_BRAND_NAME=Mi Empresa
SMOKEPING_BRAND_URL=https://www.miempresa.com

# ============================================
# PERSONALIZACIÓN DE COLORES
# ============================================
# Usa cualquier color CSS válido: #hex, rgb(), hsl()

# Color primario (botones, enlaces, acentos)
SMOKEPING_COLOR_PRIMARY=#007bff

# Color secundario (elementos secundarios)
SMOKEPING_COLOR_SECONDARY=#6c757d

# Color de acento (hover, resaltados)
SMOKEPING_COLOR_ACCENT=#00d4ff

# Fondo del sidebar
SMOKEPING_COLOR_SIDEBAR_BG=#1a1a2e

# Texto del sidebar
SMOKEPING_COLOR_SIDEBAR_TEXT=rgba(255,255,255,0.8)

# Fondo del header
SMOKEPING_COLOR_HEADER_BG=#16213e

# ============================================
# PERSONALIZACIÓN DE FUENTES
# ============================================
# Familia de fuentes (CSS font-family)
# Ejemplos: 
#   - "Poppins, sans-serif"
#   - "Roboto, Arial, sans-serif"
#   - "Inter, system-ui, sans-serif"
#   - "Outfit, sans-serif"
SMOKEPING_FONT_FAMILY=Poppins, sans-serif

# URL de Google Fonts (o vacío para fuentes del sistema)
# Ejemplos:
#   - https://fonts.googleapis.com/css?family=Poppins:300,400,500,600,700
#   - https://fonts.googleapis.com/css?family=Roboto:300,400,500,700
#   - https://fonts.googleapis.com/css?family=Inter:300,400,500,600,700
#   - https://fonts.googleapis.com/css?family=Outfit:300,400,500,600,700
SMOKEPING_FONT_URL=https://fonts.googleapis.com/css?family=Poppins:300,400,500,600,700

# ============================================
# TRACEROUTE
# ============================================
# Intervalo de ejecución de traceroute en segundos
# Por defecto: 300 (5 minutos)
TRACEPING_INTERVAL=300

# Días de retención del historial
# Por defecto: 365 (1 año)
TRACEPING_RETENTION_DAYS=365

# Puerto interno del servidor traceping (no cambiar normalmente)
TRACEPING_PORT=9000
