# ============================================
# SmokePing Docker - Main Configuration
# ============================================

# --- Server System ---
# Traefik public domain (e.g., smokeping.example.com)
DOMAIN=localhost
# Email for Let's Encrypt certificate registration
ACME_EMAIL=admin@example.com

# Standard User/Group IDs
PUID=1000
PGID=1000
# Timezone
TZ=Europe/Madrid

# --- Site Identity ---
SMOKEPING_OWNER=Neo
SMOKEPING_CONTACT=neo@matrix.com
# SMOKEPING_HOSTNAME: Displayed in "Last 3 Hours from..." and "Traceroute - ..." graphs
SMOKEPING_HOSTNAME=monitor-node-1
SMOKEPING_TITLE=Network Monitor

# --- Branding (Logo and Footer) ---
SMOKEPING_BRAND_NAME=My Company
SMOKEPING_BRAND_URL=https://mycompany.com
# Logo: Place your file in config/ or mount a volume to /usr/share/webapps/smokeping/images/
# Default uses internal path: images/logo.svg
SMOKEPING_LOGO_URL=images/logo.svg

# ============================================
# THEMES & COLORS
# ============================================
# Support for HEX, RGB, HSL

# --- Matrix Theme (Example) ---
# SMOKEPING_COLOR_PRIMARY=#00cc00
# SMOKEPING_COLOR_SECONDARY=#111111
# SMOKEPING_COLOR_ACCENT=#33ff33
# SMOKEPING_COLOR_SIDEBAR_BG=#000000
# SMOKEPING_COLOR_SIDEBAR_TEXT=#00cc00
# SMOKEPING_COLOR_HEADER_BG=#0a0a0a

# --- Classic Blue Theme (Default) ---
SMOKEPING_COLOR_PRIMARY=#007bff
SMOKEPING_COLOR_SECONDARY=#6c757d
SMOKEPING_COLOR_ACCENT=#00d4ff
SMOKEPING_COLOR_SIDEBAR_BG=#1a1a2e
SMOKEPING_COLOR_SIDEBAR_TEXT=rgba(255,255,255,0.8)
SMOKEPING_COLOR_HEADER_BG=#16213e

# Fonts (Google Fonts)
SMOKEPING_FONT_FAMILY=Poppins, sans-serif
SMOKEPING_FONT_URL=https://fonts.googleapis.com/css?family=Poppins:300,400,500,600,700

# ============================================
# TRACEROUTE SETTINGS
# ============================================
# Execution interval (seconds)
TRACEPING_INTERVAL=300
# History retention (days)
TRACEPING_RETENTION_DAYS=365
# Backend internal port
TRACEPING_PORT=9000
